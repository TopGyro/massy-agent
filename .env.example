# ─── Massy Supply Chain Intelligence Agent ───────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run:
#   docker compose up
#
# The agent will be available at http://localhost:8501
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — required for agent reasoning and tool-calling
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# AWS — read access to DynamoDB tables (inventory, orders, locations)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# DynamoDB table name prefix (default matches Terraform project name)
PROJECT_NAME=massy-agent
